# App
NEXT_PUBLIC_APP_URL=https://adoptions.happyfactory.app

# Database (Neon)
DATABASE_URL=postgresql://user:pass@host/adoptions_db

# Auth (iron-session)
SESSION_SECRET=at-least-32-characters-long-random-secret

# Test login (dev/preview only)
TEST_LOGIN_EMAIL=test@example.com
TEST_LOGIN_PASSWORD=test-password
NEXT_PUBLIC_ENABLE_TEST_LOGIN=true

# Email (Resend)
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@happyfactory.app

# AI (Anthropic)
ANTHROPIC_API_KEY=sk-ant-...

# shelter-ai integration (optional — cross-app dog data)
SHELTER_API_URL=https://shelter.happyfactory.app
SHELTER_API_SECRET=shared-secret-for-internal-calls
